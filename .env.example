# =============================================================================
# PLACEHOLDERS ÚNICAMENTE — copiar a .env y reemplazar con tus valores.
# No subas .env al repositorio ni pegues API keys reales en documentación.
# =============================================================================

# Open-Meteo (sin key): reintentos y tiempos (ver weather_client.py)
# WEATHER_HTTP_RETRIES=3
# WEATHER_HTTP_TIMEOUT_SEC=30
# WEATHER_HTTP_BACKOFF_SEC=0.7

# Logging en consola (stderr): DEBUG | INFO | WARNING | ERROR
# OPS_LOG_LEVEL=INFO

# Módulo 2 / 3 — debounce por zona (segundos). Por defecto 2700 = 45 min.
# ALERT_DEBOUNCE_TTL_SEC=2700

# Monitor continuo (modulo3_agente_telegram/monitor_loop.py): segundos entre consultas Open-Meteo
# MONITOR_INTERVAL_SEC=600

# Ping de monitor a Telegram cuando NO hubo alerta completa (solo si TELEGRAM_* está bien).
# 0 = por defecto: solo alertas reales + avisos cortos de debounce si aplica.
# 1 = además mensaje corto de estado (no_alert, error clima, etc.), como máximo cada TELEGRAM_MONITOR_PING_MIN_SEC s.
# Si NO defines TELEGRAM_MONITOR_PING_MIN_SEC, se usa MONITOR_INTERVAL_SEC (evita un solo ping y luego 5 min de silencio).
# TELEGRAM_MONITOR_PING=0
# TELEGRAM_MONITOR_PING_MIN_SEC=300

# -----------------------------------------------------------------------------
# Módulo 3 — Telegram (obligatorio para enviar al canal; ver README sección Telegram)
# -----------------------------------------------------------------------------
# Token del bot (BotFather). Ejemplo ficticio (no es válido):
TELEGRAM_BOT_TOKEN=123456789:AAHeEjemploPlaceholderNoUsar_EsteNoEsUnTokenReal
# Destino: canal @público  o  chat id numérico (p. ej. -1001234567890)
TELEGRAM_CHAT_ID=@tu_canal_o_grupo_demo

# -----------------------------------------------------------------------------
# Módulo 3 — LLM (opcional: sin OpenAI el agente usa plantilla determinista)
# -----------------------------------------------------------------------------
# Proveedor: ollama | openai | auto (auto: OpenAI si hay OPENAI_API_KEY; si no, Ollama)
LLM_PROVIDER=ollama

# --- Ollama (local) — sin API key en .env
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=mixtral:8x7b-instruct-v0.1-q4_0
# OLLAMA_TIMEOUT_SEC=180

# --- OpenAI — solo placeholders; nunca commitear la clave real
# OPENAI_API_KEY=sk-proj-EJEMPLO-PLACEHOLDER-NO-VALIDO
# OPENAI_MODEL=gpt-4o-mini
# USE_LANGCHAIN=1

# No usado por el código actual del caso (reservado si amplías proveedores):
# ANTHROPIC_API_KEY=sk-ant-api03-EJEMPLO-PLACEHOLDER
